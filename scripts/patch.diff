+# Iterate all supported CVEs and display whether the CPU vendor reports the
+# current CPU model as affected (VULN) or not (OK) for each CVE.
+# Unlike check_cpu_vulnerabilities, this outputs full pvulnstatus messages
+# and can be used together with --hw-only.
+check_vendor_status() {
+    local cve
+    pr_info "\033[1;34mCPU vendor affectedness\033[0m"
+    for cve in $g_supported_cve_list; do
+        if ! _is_cve_relevant_arch "$cve"; then
+            pr_debug "vendor-status: skipping $cve (arch tag not relevant)"
+            continue
+        fi
+        if is_cpu_affected "$cve"; then
+            pvulnstatus "$cve" VULN "your CPU vendor reported your CPU model as affected"
+        else
+            pvulnstatus "$cve" OK "your CPU vendor reported your CPU model as not affected"
+        fi
+        pr_info
+    done
+}
